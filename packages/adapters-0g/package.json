{
  "name": "@agentraft/adapters-0g",
  "version": "0.1.0",
  "description": "AgentRaft adapters: 0G Storage (LogStore), 0G Chain (ConsensusGate, IdentityProvider), 0G Compute (TEE-verified Agent helper).",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "contracts/*.sol", "README.md"],
  "scripts": {
